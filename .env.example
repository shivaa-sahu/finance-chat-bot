# App
NEXT_PUBLIC_API_BASE=http://localhost:3000/api
NEXT_PUBLIC_WS_URL=http://localhost:3000
APP_PORT=3000

# NestJS
BACKEND_PORT=4000
JWT_SECRET=hello-from-finance-chatbot
JWT_EXPIRES_IN=7d

# Database
DATABASE_URL=postgresql://postgres:postgres@db:5432/deepfin?schema=public

# Redis
REDIS_URL=redis://redis:6379/0

# Agent
AGENT_HOST=http://agent:8000
AGENT_API_KEY=replace_agent_key

# Vector store config
VECTOR_PROVIDER=pgvector   # options: pgvector|pinecone|mongo
VECTOR_PG_CONNECTION=postgresql://postgres:postgres@db:5432/deepfin
# Pinecone example
# PINECONE_API_KEY=
# PINECONE_ENV=

# Search providers (configurable)
SERPER_API_KEY=
BING_SEARCH_KEY=
OPENAI_API_KEY=
GENIE_API_KEY=

# Embedding provider
EMBEDDING_PROVIDER=openai
